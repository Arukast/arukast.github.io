---
import profile from '../data/profile.json';

const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '';
---

<header id="main-header" class="sticky top-0 z-40 w-full pointer-events-none">
  <div id="navbar-container" class="mx-auto flex justify-between items-center gap-4 pointer-events-auto">
    <div class="flex items-center gap-2">
      <a href="/" class="font-mono text-[13px] sm:text-sm tracking-tight hover:opacity-80 flex items-center gap-1">
        <span class="text-[var(--accent-primary)]"><i class="fa-solid fa-terminal"></i></span>
        <span class="font-bold">{profile.username}</span><span class="font-bold logo-domain">@{profile.domain}</span><span class="text-zinc-400 logo-text-desktop">:~#</span>
      </a>
    </div>

    <!-- Navigation Tabs -->
    <nav class="flex gap-3 sm:gap-5 text-[13px] sm:text-sm font-mono">
      <a href={isHome ? "#home" : "/"} class="nav-link text-zinc-400 py-1" data-nav="home">
        /home
      </a>
      <a href={isHome ? "#profile" : "/#profile"} class="nav-link text-zinc-400 py-1" data-nav="profile">
        ~#profile
      </a>
      <a href={isHome ? "#terminal-root" : "/#terminal-root"} class="nav-link text-zinc-400 py-1" data-nav="terminal">
        ~#terminal
      </a>
      <a href={isHome ? "#core-projects" : "/#core-projects"} class="nav-link text-zinc-400 py-1" data-nav="projects">
        ~#projects
      </a>
    </nav>
  </div>
</header>

<style>
  /* Outer sticky header background & border on top of page */
  header {
    background-color: rgba(9, 9, 11, 0.9);
    border-bottom: 1px solid var(--border-color);
    backdrop-filter: blur(12px);
    transition: background-color 0.5s ease, border-color 0.5s ease, backdrop-filter 0.5s ease;
  }
  
  header.is-scrolled {
    background-color: transparent;
    border-color: transparent;
    backdrop-filter: none;
  }

  /* Default Inner Header Container aligned with grid */
  #navbar-container {
    width: 100%;
    max-width: 48rem; /* max-w-3xl */
    padding: 1rem 1.5rem;
    border: 1px solid transparent;
    border-radius: 0;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Floating Island HUD State (Active when scrolled) */
  #navbar-container.is-scrolled {
    margin-top: 0.75rem;
    max-width: 620px;
    border-radius: 9999px;
    border: 1px solid rgba(16, 185, 129, 0.25);
    background-color: rgba(9, 9, 11, 0.85);
    backdrop-filter: blur(12px);
    box-shadow: 0 0 24px rgba(16, 185, 129, 0.05), 0 10px 30px rgba(0, 0, 0, 0.6);
    padding: 0.5rem 1.25rem;
  }

  .logo-domain {
    display: inline-block;
    max-width: 150px;
    opacity: 1;
    overflow: hidden;
    white-space: nowrap;
    transition: max-width 0.5s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease;
    vertical-align: bottom;
  }

  /* Collapse the domain name on scroll to keep the island compact and clean */
  #navbar-container.is-scrolled .logo-domain {
    max-width: 0px;
    opacity: 0;
  }

  @media (max-width: 640px) {
    #navbar-container {
      padding: 1rem;
    }
    
    #navbar-container.is-scrolled {
      max-width: calc(100% - 2rem);
      padding: 0.5rem 1rem;
    }
    
    /* Hide prompt symbol on mobile scrolled island to save space */
    #navbar-container.is-scrolled .logo-text-desktop {
      display: none;
    }
  }

  /* Active glow effect */
  :global(.active-glow) {
    color: var(--accent-primary) !important;
    text-shadow: 0 0 10px rgba(16, 185, 129, 0.5);
    font-weight: 600;
  }
  
  .nav-link {
    transition: all 0.3s ease;
  }
  
  .nav-link:hover {
    color: var(--accent-primary);
    text-shadow: 0 0 8px rgba(16, 185, 129, 0.3);
  }
</style>

<script>
  function setupNavbar() {
    const header = document.getElementById('main-header');
    const container = document.getElementById('navbar-container');
    const links = document.querySelectorAll('.nav-link');
    
    // Toggle header style on scroll
    function onScroll() {
      if (window.scrollY > 20) {
        header?.classList.add('is-scrolled');
        container?.classList.add('is-scrolled');
      } else {
        header?.classList.remove('is-scrolled');
        container?.classList.remove('is-scrolled');
      }
    }

    // Add scroll event listener with passive: true for performance
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // IntersectionObserver for Scroll Spy - completely avoids forced reflow / layout thrashing
    const sections = [
      { id: 'home', nav: 'home' },
      { id: 'profile', nav: 'profile' },
      { id: 'terminal-root', nav: 'terminal' },
      { id: 'core-projects', nav: 'projects' }
    ];
    
    const isCurrentHome = window.location.pathname === '/' || window.location.pathname === '';
    let observer: IntersectionObserver | null = null;

    if (isCurrentHome) {
      const activeSections = new Map<string, boolean>();

      const observerOptions = {
        root: null,
        rootMargin: '-30% 0px -40% 0px', // focused viewport center band
        threshold: 0
      };

      observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          activeSections.set(entry.target.id, entry.isIntersecting);
        });

        // Determine active navigation item based on intersection
        let activeNav = 'home';
        if (activeSections.get('core-projects')) {
          activeNav = 'projects';
        } else if (activeSections.get('terminal-root')) {
          activeNav = 'terminal';
        } else if (activeSections.get('profile')) {
          activeNav = 'profile';
        } else if (activeSections.get('home')) {
          activeNav = 'home';
        }

        // Fallback for very top of the page
        if (window.scrollY < 50) {
          activeNav = 'home';
        }

        links.forEach(link => {
          const nav = link.getAttribute('data-nav');
          if (nav === activeNav) {
            link.classList.add('active-glow');
            link.classList.remove('text-zinc-400');
          } else {
            link.classList.remove('active-glow');
            link.classList.add('text-zinc-400');
          }
        });
      }, observerOptions);

      sections.forEach(section => {
        const el = document.getElementById(section.id);
        if (el) observer?.observe(el);
      });
    } else {
      // Clear active styling if not home
      links.forEach(link => {
        link.classList.remove('active-glow');
        link.classList.add('text-zinc-400');
      });
    }

    // Add smooth scroll behavior for same-page clicks
    links.forEach(link => {
      link.addEventListener('click', (e) => {
        const href = link.getAttribute('href');
        const isHome = window.location.pathname === '/' || window.location.pathname === '';
        
        if (isHome && href && href.includes('#')) {
          const hashIndex = href.indexOf('#');
          const hash = href.substring(hashIndex);
          
          e.preventDefault();
          if (hash === '#' || hash === '#home') {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          } else {
            const targetEl = document.querySelector(hash);
            if (targetEl) {
              targetEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
          }
        }
      });
    });

    // Cleanup listeners and observer on before-swap to prevent memory leaks / duplicates
    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', onScroll);
      if (observer) {
        observer.disconnect();
      }
    }, { once: true });
  }

  // Handle Astro page transition load
  document.addEventListener('astro:page-load', setupNavbar);
</script>
