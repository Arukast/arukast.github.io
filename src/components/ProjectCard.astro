---
interface Props {
  slug: string;
  title: string;
  description: string;
  category: string;
  status: string;
  tags: string[];
  githubUrl: string;
  architecture?: string[];
  expanded?: boolean;
  icon?: string;
}

const {
  slug,
  title,
  description,
  category,
  status,
  tags,
  githubUrl,
  architecture = [],
  expanded = false,
  icon = "fa-cube"
} = Astro.props;

const statusColorMap: Record<string, string> = {
  'PRODUCTION': 'bg-emerald-950/20 text-emerald-400 border-emerald-900/40',
  'ONLINE': 'bg-emerald-950/20 text-emerald-400 border-emerald-900/40',
  'BLUEPRINT': 'bg-indigo-950/20 text-indigo-400 border-indigo-900/40',
  'STABLE': 'bg-zinc-900 text-zinc-400 border-[var(--border-color)]'
};

const statusColor = statusColorMap[status.toUpperCase()] || 'bg-zinc-900 text-zinc-400 border-[var(--border-color)]';
---

{expanded ? (
  // Expanded project card layout for /projects catalog list
  <div class="p-6 bg-[var(--bg-secondary)]/40 border border-[var(--border-color)] rounded-2xl space-y-4">
    <div class="flex flex-wrap items-center justify-between gap-2">
      <div class="flex items-center gap-2">
        <span class="text-xl text-[var(--accent-primary)]"><i class={`fa-solid ${icon}`}></i></span>
        <h3 class="text-lg font-bold font-mono text-white">{title}</h3>
      </div>
      <span class={`text-xs font-mono border px-2.5 py-0.5 rounded-md ${statusColor}`}>
        STATUS: {status.toUpperCase()}
      </span>
    </div>

    <p class="text-sm text-zinc-300 leading-relaxed">
      {description}
    </p>

    {architecture && architecture.length > 0 && (
      <div class="bg-zinc-950 p-4 rounded-xl border border-[var(--border-color)] font-mono text-xs text-zinc-400 space-y-2">
        <p class="text-zinc-500">// System Architecture</p>
        <div class="flex flex-wrap items-center gap-2 text-sm">
          {architecture.map((node, index) => (
            <>
              {index > 0 && <span class="text-zinc-600">→</span>}
              <span class={`bg-zinc-900 border border-zinc-800 px-2.5 py-1 rounded text-zinc-300 ${index === 1 ? 'font-semibold text-[var(--accent-primary)]' : ''}`}>
                {node}
              </span>
            </>
          ))}
        </div>
      </div>
    )}

    <div class="flex flex-wrap justify-between items-center gap-3 pt-2">
      <div class="flex gap-2 text-xs font-mono text-zinc-500">
        {tags.map(tag => (
          <span class="bg-zinc-900 px-2 py-0.5 rounded border border-zinc-800">{tag}</span>
        ))}
      </div>
      <div class="flex items-center gap-4">
        <a href={`/projects/${slug}`} class="text-sm font-mono text-zinc-400 hover:text-white hover:underline flex items-center gap-1">
          view_case_study <i class="fa-solid fa-file-lines text-xs"></i>
        </a>
        <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="text-sm font-mono text-[var(--accent-primary)] hover:underline flex items-center gap-1.5">
          <i class="fa-brands fa-github"></i> view_sources.git
        </a>
      </div>
    </div>
  </div>
) : (
  // Minimalized project card layout for /home page preview
  <div class="group p-6 bg-[var(--bg-secondary)]/30 border border-[var(--border-color)] rounded-xl hover:bg-[var(--bg-secondary)]/60 hover:border-zinc-700 transition-all duration-300 flex flex-col justify-between">
    <div>
      <div class="flex flex-wrap justify-between items-center gap-2 mb-3">
        <span class="text-sm font-mono text-zinc-400 bg-zinc-900 border border-[var(--border-color)] px-2.5 py-0.5 rounded">
          {category}
        </span>
        <span class="text-sm text-zinc-400 font-mono font-medium">{status}</span>
      </div>
      <h3 class="text-lg font-bold group-hover:text-[var(--accent-primary)] transition-colors mb-2">
        {title}
      </h3>
      <p class="text-[15px] text-zinc-300 leading-relaxed mb-4 line-clamp-3">
        {description}
      </p>
    </div>
    <div class="flex items-center justify-between mt-2 pt-3 border-t border-zinc-900/60">
      <div class="flex gap-1.5 text-xs font-mono text-zinc-400">
        {tags.slice(0, 2).map(tag => (
          <span class="bg-zinc-900 px-2.5 py-0.5 rounded border border-zinc-800/80">{tag}</span>
        ))}
      </div>
      <a href={`/projects/${slug}`} class="text-sm font-mono text-[var(--accent-primary)] hover:underline flex items-center gap-1">
        view_design <i class="fa-solid fa-angle-right"></i>
      </a>
    </div>
  </div>
)}
