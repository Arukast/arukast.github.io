---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Terminal from '../components/Terminal.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Footer from '../components/Footer.astro';

import { getCollection } from 'astro:content';
import profile from '../data/profile.json';

const allProjects = await getCollection('projects');

// Sort all projects by order (ascending)
const sortedProjects = [...allProjects].sort((a, b) => {
  const orderA = a.data.order ?? 999;
  const orderB = b.data.order ?? 999;
  return orderA - orderB;
});

// Filter featured projects by frontmatter flag (fallback to defaults if none marked)
const hasFeaturedField = allProjects.some(project => project.data.featured === true);
const featuredProjects = hasFeaturedField 
  ? sortedProjects.filter(project => project.data.featured === true)
  : sortedProjects.filter(project => project.id === 'api-queue' || project.id === 'ingress-tunnel');
---

<Layout>
  <!-- Minimal System Header Console Bar -->
  <Navbar />

  <main class="flex-grow max-w-5xl w-full mx-auto px-6 py-10 space-y-12">
    <!-- Home / Hero Section -->
    <section id="home" class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center min-h-[calc(100vh-6rem)] py-6 lg:py-12 border-b border-[var(--border-color)]/40">
      <!-- Left Column: Intro -->
      <div class="lg:col-span-7 space-y-8">
        <div class="space-y-4">
          <h1 class="text-4xl sm:text-5xl md:text-6xl font-medium tracking-tight leading-tight">
            Hi all, I'm <span class="text-[var(--accent-primary)]">{profile.name.split(' (')[0]}</span> 👋
          </h1>
          <p class="text-base sm:text-lg md:text-xl text-zinc-300 leading-relaxed font-normal">
            A passionate <span class="text-white font-medium">{profile.title}</span> having an experience of building self-hosted homelabs, virtualization infrastructure with Proxmox/Docker, and automated DevOps pipelines.
          </p>
        </div>
 
        <!-- Social Media List -->
        <div class="flex flex-wrap items-center gap-3.5 pt-2">
          <a href={profile.socials.github} target="_blank" rel="noopener noreferrer" title="GitHub Infrastructure Code" class="flex items-center justify-center w-11 h-11 rounded-full bg-zinc-800 text-white hover:bg-zinc-700 hover:scale-110 transition duration-300 text-xl shadow-md">
            <i class="fa-brands fa-github"></i>
          </a>
          <a href={profile.socials.linkedin} target="_blank" rel="noopener noreferrer" title="LinkedIn Engineering Profile" class="flex items-center justify-center w-11 h-11 rounded-full bg-[#0077b5] text-white hover:brightness-110 hover:scale-110 transition duration-300 text-xl shadow-md">
            <i class="fa-brands fa-linkedin-in"></i>
          </a>
          <a href={`mailto:${profile.socials.email}`} title="Email Developer Direct" class="flex items-center justify-center w-11 h-11 rounded-full bg-[#ea4335] text-white hover:brightness-110 hover:scale-110 transition duration-300 text-xl shadow-md">
            <i class="fa-solid fa-envelope"></i>
          </a>
        </div>
 
        <!-- CTA Action Buttons -->
        <div class="flex flex-wrap gap-5 pt-2">
          <a href={`mailto:${profile.socials.email}`} class="inline-flex items-center justify-center font-sans text-xs font-bold tracking-widest uppercase bg-[var(--accent-primary)] hover:bg-emerald-400 text-black px-8 py-4 rounded-md transition duration-300 cursor-pointer shadow-lg shadow-emerald-500/10">
            CONTACT ME
          </a>
          <a href={profile.cvUrl} download class="inline-flex items-center justify-center font-sans text-xs font-bold tracking-widest uppercase bg-zinc-900 hover:bg-zinc-800 text-zinc-200 border border-[var(--border-color)] hover:border-zinc-700 px-8 py-4 rounded-md transition duration-300 cursor-pointer">
            DOWNLOAD MY RESUME
          </a>
        </div>
      </div>
 
      <!-- Right Column: Visual ASCII -->
      <div class="lg:col-span-5 flex justify-center items-center w-full">
        <svg viewBox="0 0 440 125" class="w-full h-auto text-[var(--accent-primary)] drop-shadow-[0_0_15px_rgba(16,185,129,0.25)] select-none" xmlns="http://www.w3.org/2000/svg">
          <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" font-family="JetBrains Mono, monospace" font-weight="bold" font-size="12" xml:space="preserve" class="whitespace-pre fill-current">
            <tspan x="50%" dy="-4em">____________________/\\\________/\\\_________________________</tspan>
            <tspan x="50%" dy="1.15em"> ___________________\/\\\_______\/\\\_________________________</tspan>
            <tspan x="50%" dy="1.15em">  ____/\\\\\_________\/\\\_______\/\\\__/\\\____/\\\\\_________</tspan>
            <tspan x="50%" dy="1.15em">   __/\\\///\\\__/\\\_\/\\\\\\\\\\\\\\\_\///___/\\\///\\\__/\\\_</tspan>
            <tspan x="50%" dy="1.15em">    _\///__\///\\\\\/__\/\\\/////////\\\__/\\\_\///__\///\\\\\/__</tspan>
            <tspan x="50%" dy="1.15em">     _________\/////____\/\\\_______\/\\\_\/\\\_________\/////____</tspan>
            <tspan x="50%" dy="1.15em">      ___________________\/\\\_______\/\\\_\/\\\___________________</tspan>
            <tspan x="50%" dy="1.15em">       ___________________\/\\\_______\/\\\_\/\\\___________________</tspan>
            <tspan x="50%" dy="1.15em">        ___________________\///________\///__\///____________________</tspan>
          </text>
        </svg>
      </div>
    </section>

    <!-- Profile Section -->
    <section id="profile" class="flex flex-col items-center text-center p-8 rounded-2xl border border-[var(--border-color)] bg-[var(--bg-secondary)]/30 relative overflow-hidden backdrop-blur-sm">
      <div class="absolute -right-12 -top-12 w-48 h-48 bg-[var(--accent-primary)]/5 rounded-full blur-3xl pointer-events-none"></div>
      
      <div class="text-[10px] font-mono text-zinc-400 uppercase tracking-widest mb-6 select-none">// DETAILED_PROFILE_MANIFEST</div>

      <!-- Avatar with pulse indicator -->
      <div class="relative mb-6">
        <img src={profile.avatarUrl} alt="Profile Avatar" onerror="this.src='https://placehold.co/150x150/111/fff?text=User'" class="w-56 h-56 rounded-2xl border border-[var(--border-color)] object-cover shadow-lg p-2.5 bg-zinc-900" />
        <div class="absolute -bottom-1 -right-1 w-9 h-9 bg-emerald-500 border-4 border-[var(--bg-primary)] rounded-full"></div>
      </div>

      <!-- Bio Details -->
      <div class="space-y-4 max-w-3xl">
        <span class="inline-block mb-1.5 text-xs font-mono uppercase tracking-widest text-emerald-400 font-medium bg-emerald-950/20 px-3 py-1.5 rounded-md border border-emerald-900/30">
          {profile.title}
        </span>
        <h1 class="text-3xl md:text-4xl font-bold tracking-tight">{profile.name}</h1>
        <p class="text-base text-zinc-300 leading-relaxed">
          {profile.bio}
        </p>
      </div>

      <!-- Social Media List -->
      <div class="flex items-center justify-center gap-7 mt-6 pt-6 border-t border-zinc-900/60 w-full max-w-lg">
        <a href={profile.socials.github} target="_blank" rel="noopener noreferrer" title="GitHub Infrastructure Code" class="text-zinc-400 hover:text-[var(--accent-primary)] transition-all transform hover:scale-110 text-2xl">
          <i class="fa-brands fa-github"></i>
        </a>
        <a href={profile.socials.linkedin} target="_blank" rel="noopener noreferrer" title="LinkedIn Engineering Profile" class="text-zinc-400 hover:text-[var(--accent-primary)] transition-all transform hover:scale-110 text-2xl">
          <i class="fa-brands fa-linkedin"></i>
        </a>
        <a href={`mailto:${profile.socials.email}`} title="Email Developer Direct" class="text-zinc-400 hover:text-[var(--accent-primary)] transition-all transform hover:scale-110 text-2xl">
          <i class="fa-solid fa-envelope"></i>
        </a>
        <a href={profile.cvUrl} download title="Download Resume (PDF)" class="text-zinc-400 hover:text-[var(--accent-primary)] transition-all transform hover:scale-110 text-2xl">
          <i class="fa-solid fa-file-pdf"></i>
        </a>
      </div>
    </section>

    <!-- Interactive CLI Terminal Simulator (sys_diagnose.sh) -->
    <Terminal />

    <!-- Featured Project Previews -->
    <section id="core-projects" class="space-y-6">
      <div class="flex justify-between items-center border-b border-[var(--border-color)] pb-3">
        <h2 class="font-mono text-sm font-bold uppercase tracking-wider text-zinc-300 flex items-center gap-2">
          <span class="text-[var(--accent-primary)]">//</span> Core Projects Overview
        </h2>
        <span class="text-xs bg-zinc-900/60 px-2.5 py-0.5 rounded border border-[var(--border-color)] text-zinc-400 font-mono">
          Standout Cases
        </span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {featuredProjects.map(project => (
          <ProjectCard
            slug={project.id}
            title={project.data.title}
            description={project.data.description}
            category={project.data.category}
            status={project.data.status}
            tags={project.data.tags}
            githubUrl={project.data.githubUrl}
            liveUrl={project.data.liveUrl}
            architecture={project.data.architecture}
            expanded={false}
            icon={project.data.icon}
            image={project.data.image}
          />
        ))}
      </div>

      <!-- Deep Project Directory Target Link -->
      <div class="pt-4 text-center">
        <a href="/projects" class="inline-flex items-center gap-2 font-mono text-sm text-[var(--accent-primary)] hover:text-emerald-300 transition group bg-[var(--bg-secondary)] border border-[var(--border-color)] hover:border-zinc-700 px-6 py-3.5 rounded-xl cursor-pointer">
          <i class="fa-solid fa-folder-open"></i> VIEW COMPREHENSIVE PROJECT DIRECTORY
          <i class="fa-solid fa-arrow-right text-sm group-hover:translate-x-1.5 transition-transform duration-300"></i>
        </a>
      </div>
    </section>

  </main>

  <!-- Minimal System Footer -->
  <Footer />
</Layout>

