---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import Footer from '../../components/Footer.astro';

import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
---

<Layout title="sys_admin@portfolio:~/projects_inventory# - Projects Registry">
  <Navbar />

  <main class="flex-grow max-w-5xl w-full mx-auto px-6 py-10 space-y-8">
    <section class="space-y-4">
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-2 border-b border-[var(--border-color)] pb-4">
        <div>
          <span class="text-xs font-mono uppercase tracking-widest text-zinc-400">Root Directory</span>
          <h1 class="text-2xl font-bold font-mono tracking-tight text-white mt-1">
            <a href="/" class="text-zinc-400 hover:text-[var(--accent-primary)] transition-colors">/home</a>/projects_inventory
          </h1>
        </div>
        <a href="/" class="text-xs font-mono text-zinc-400 hover:text-[var(--accent-primary)] transition flex items-center gap-1.5 bg-zinc-900 border border-[var(--border-color)] px-3 py-1.5 rounded-lg">
          <i class="fa-solid fa-arrow-left"></i> back_to_home
        </a>
      </div>
      <p class="text-base text-zinc-300 leading-relaxed max-w-xl">
        A comprehensive registry of deep systems, backend microservices, and automation pipelines built throughout my infrastructure development career.
      </p>
    </section>

    <!-- Project List Matrix -->
    <section class="space-y-6">
      {projects.map(project => (
        <ProjectCard
          slug={project.id}
          title={project.data.title}
          description={project.data.description}
          category={project.data.category}
          status={project.data.status}
          tags={project.data.tags}
          githubUrl={project.data.githubUrl}
          liveUrl={project.data.liveUrl}
          architecture={project.data.architecture}
          expanded={true}
          icon={project.data.icon}
          image={project.data.image}
        />
      ))}
    </section>
  </main>

  <Footer />
</Layout>
