---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

import { render } from 'astro:content';

const { entry } = Astro.props;
const { Content } = await render(entry);


const statusColorMap: Record<string, string> = {
  'PRODUCTION': 'bg-emerald-950/20 text-emerald-400 border-emerald-900/40',
  'ONLINE': 'bg-emerald-950/20 text-emerald-400 border-emerald-900/40',
  'BLUEPRINT': 'bg-indigo-950/20 text-indigo-400 border-indigo-900/40',
  'STABLE': 'bg-zinc-900 text-zinc-400 border-[var(--border-color)]'
};

const statusColor = statusColorMap[entry.data.status.toUpperCase()] || 'bg-zinc-900 text-zinc-400 border-[var(--border-color)]';
---

<Layout title={entry.data.title} description={entry.data.description}>
  <Navbar />

  <main class="flex-grow max-w-5xl w-full mx-auto px-6 py-10 space-y-8">
    <section class="space-y-4">
      <!-- Back button and Navigation Context -->
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 text-sm font-mono text-zinc-400 w-full overflow-hidden">
        <div class="block w-full break-all text-xs sm:text-sm">
          <a href="/" class="hover:text-[var(--accent-primary)] transition-colors">/home</a>/<a href="/projects" class="hover:text-[var(--accent-primary)] transition-colors">projects_inventory</a>/{entry.id}.md
        </div>
        <a href="/projects" class="text-zinc-400 hover:text-[var(--accent-primary)] transition flex items-center gap-1.5 bg-zinc-900 border border-[var(--border-color)] px-2.5 py-1 rounded-lg shrink-0">
          <i class="fa-solid fa-arrow-left"></i> back_to_directory
        </a>
      </div>

      <!-- Title Header Block -->
      <div class="border-b border-[var(--border-color)] pb-6 space-y-3">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <h1 class="text-2xl sm:text-3xl font-bold font-mono text-white tracking-tight">{entry.data.title}</h1>
          <span class={`text-xs font-mono border px-2.5 py-0.5 rounded-md ${statusColor}`}>
            {entry.data.status}
          </span>
        </div>

        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs font-mono text-zinc-400">
          <span><strong class="text-zinc-300">Category:</strong> {entry.data.category}</span>
          <span>•</span>
          <div class="flex flex-wrap gap-1.5">
            {entry.data.tags.map(tag => (
              <span class="bg-zinc-900 px-2 py-0.5 rounded border border-zinc-800 text-[11px] text-zinc-400">{tag}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Project Hero Image Banner if available -->
    {entry.data.image && (
      <section class="w-full overflow-hidden rounded-2xl border border-[var(--border-color)] bg-zinc-950/40">
        <img 
          src={entry.data.image} 
          alt={`${entry.data.title} - Showcase`} 
          class="w-full h-64 md:h-[400px] object-cover opacity-90 hover:opacity-100 transition-opacity duration-300"
        />
      </section>
    )}

    <!-- Project Architecture flow diagram if available -->
    {entry.data.architecture && entry.data.architecture.length > 0 && (
      <section class="bg-zinc-950 p-5 rounded-xl border border-[var(--border-color)] font-mono text-[11px] text-zinc-400 space-y-3">
        <p class="text-zinc-400">// Infrastructure Path Flow</p>
        <div class="flex flex-wrap items-center gap-y-3 gap-x-2.5 text-xs">
          {entry.data.architecture.map((node, index) => (
            <>
              {index > 0 && (
                <i class="fa-solid fa-arrow-right text-xs text-[var(--accent-primary)] opacity-80 shrink-0 px-0.5"></i>
              )}
              <span class="bg-zinc-900 border border-zinc-800 px-3 py-1.5 rounded text-zinc-200 font-medium">
                {node}
              </span>
            </>
          ))}
        </div>
      </section>
    )}

    <!-- Dynamic Markdown Content Container -->
    <article class="project-content">
      <Content />
    </article>

    <!-- Project Gallery Showcase if available -->
    {entry.data.gallery && entry.data.gallery.length > 0 && (
      <section class="space-y-4 pt-6 border-t border-[var(--border-color)]">
        <h3 class="text-sm font-mono uppercase tracking-widest text-zinc-400">// Project Screenshots & Gallery</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
          {entry.data.gallery.map((img, idx) => {
            const isHidden = idx >= 6;
            const isLastVisible = idx === 5 && entry.data.gallery!.length > 6;
            return (
              <div class={`group relative overflow-hidden rounded-xl border border-[var(--border-color)] bg-zinc-950/40 cursor-zoom-in aspect-video ${isHidden ? 'hidden' : ''}`}>
                <img 
                  src={img} 
                  alt={`${entry.data.title} screenshot ${idx + 1}`} 
                  class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-102 transition-all duration-300 gallery-image"
                  data-src={img}
                />
                {isLastVisible && (
                  <div class="absolute inset-0 bg-black/75 flex flex-col items-center justify-center pointer-events-none transition-colors group-hover:bg-black/60">
                    <span class="text-white font-mono text-2xl font-bold">
                      +{entry.data.gallery!.length - 5}
                    </span>
                    <span class="text-[10px] font-mono text-zinc-400 uppercase tracking-widest mt-1">More Screenshots</span>
                  </div>
                )}
              </div>
            );
          })}
        </div>
      </section>
    )}

    <!-- Source / Website Link Footer -->
    {(entry.data.githubUrl || entry.data.liveUrl) && (
      <div class="pt-6 border-t border-[var(--border-color)] flex flex-wrap justify-between items-center gap-4 text-sm font-mono">
        <span class="text-zinc-400">
          {entry.data.githubUrl ? "Sources available under public GPL v3." : "Deployment online."}
        </span>
        <div class="flex flex-wrap items-center gap-4">
          {entry.data.liveUrl && (
            <a href={entry.data.liveUrl} target="_blank" rel="noopener noreferrer" class="text-[var(--accent-primary)] hover:underline flex items-center gap-1.5">
              <i class="fa-solid fa-globe text-xs"></i> live_demo.html
            </a>
          )}
          {entry.data.githubUrl && (
            <a href={entry.data.githubUrl} target="_blank" rel="noopener noreferrer" class="text-[var(--accent-primary)] hover:underline flex items-center gap-1.5">
              <i class="fa-brands fa-github"></i> view_sources.git
            </a>
          )}
        </div>
      </div>
    )}
  </main>

  <!-- Lightbox Modal -->
  <div id="lightbox" class="fixed inset-0 z-50 flex items-center justify-center bg-black/95 opacity-0 pointer-events-none transition-all duration-300">
    <button id="lightbox-close" class="absolute top-6 right-6 text-zinc-400 hover:text-white text-3xl transition" aria-label="Close Lightbox">
      <i class="fa-solid fa-xmark"></i>
    </button>
    
    <!-- Prev button -->
    <button id="lightbox-prev" class="absolute left-6 text-zinc-400 hover:text-white text-4xl transition p-2" aria-label="Previous image">
      <i class="fa-solid fa-angle-left"></i>
    </button>

    <div class="max-w-[85vw] max-h-[80vh] flex flex-col items-center gap-3">
      <img id="lightbox-img" src="" alt="Lightbox image" class="max-w-full max-h-[80vh] rounded-lg border border-zinc-800 object-contain shadow-2xl" />
      <span id="lightbox-counter" class="text-xs font-mono text-zinc-400"></span>
    </div>

    <!-- Next button -->
    <button id="lightbox-next" class="absolute right-6 text-zinc-400 hover:text-white text-4xl transition p-2" aria-label="Next image">
      <i class="fa-solid fa-angle-right"></i>
    </button>
  </div>

  <Footer />
</Layout>

<script>
  function initLightbox() {
    const galleryImages = document.querySelectorAll('.gallery-image') as NodeListOf<HTMLImageElement>;
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lightboxClose = document.getElementById('lightbox-close');
    const lightboxPrev = document.getElementById('lightbox-prev');
    const lightboxNext = document.getElementById('lightbox-next');
    const lightboxCounter = document.getElementById('lightbox-counter');

    let currentIndex = 0;

    if (lightbox && lightboxImg && lightboxClose && lightboxPrev && lightboxNext && lightboxCounter && galleryImages.length > 0) {
      const updateLightbox = (index: number) => {
        currentIndex = index;
        const img = galleryImages[currentIndex];
        if (img) {
          lightboxImg.src = img.getAttribute('data-src') || img.src;
          lightboxCounter.textContent = `${currentIndex + 1} / ${galleryImages.length}`;
        }
      };

      galleryImages.forEach((img, idx) => {
        const parent = img.parentElement;
        if (parent) {
          parent.addEventListener('click', () => {
            updateLightbox(idx);
            lightbox.classList.remove('opacity-0', 'pointer-events-none');
          });
        }
      });

      const showPrev = () => {
        const nextIdx = (currentIndex - 1 + galleryImages.length) % galleryImages.length;
        updateLightbox(nextIdx);
      };

      const showNext = () => {
        const nextIdx = (currentIndex + 1) % galleryImages.length;
        updateLightbox(nextIdx);
      };

      const closeLightbox = () => {
        lightbox.classList.add('opacity-0', 'pointer-events-none');
        setTimeout(() => {
          lightboxImg.src = '';
        }, 300);
      };

      lightboxPrev.addEventListener('click', (e) => {
        e.stopPropagation();
        showPrev();
      });

      lightboxNext.addEventListener('click', (e) => {
        e.stopPropagation();
        showNext();
      });

      lightboxClose.addEventListener('click', closeLightbox);
      lightbox.addEventListener('click', (e) => {
        if (e.target === lightbox) {
          closeLightbox();
        }
      });

      document.addEventListener('keydown', (e) => {
        if (lightbox.classList.contains('pointer-events-none')) return;
        if (e.key === 'Escape') {
          closeLightbox();
        } else if (e.key === 'ArrowLeft') {
          showPrev();
        } else if (e.key === 'ArrowRight') {
          showNext();
        }
      });
    }
  }

  // Initialize on page load and astro page transition
  document.addEventListener('astro:page-load', initLightbox);
</script>

<style is:global>
  /* Markdown Typography overrides */
  .project-content h1,
  .project-content h2,
  .project-content h3,
  .project-content h4 {
    color: #f4f4f5;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 6px;
    margin-top: 28px;
    margin-bottom: 12px;
    text-transform: uppercase;
    font-family: 'JetBrains Mono', monospace;
    font-weight: bold;
  }
  .project-content h1 { font-size: 20px; }
  .project-content h2 { font-size: 18px; }
  .project-content h3 { font-size: 16px; }
  .project-content h4 { font-size: 14px; }

  .project-content p,
  .project-content ul,
  .project-content ol {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    margin-bottom: 14px;
    color: #a1a1aa;
  }
  .project-content ul {
    list-style-type: square;
    padding-left: 20px;
  }
  .project-content ol {
    list-style-type: decimal;
    padding-left: 20px;
  }
  .project-content li {
    margin-bottom: 6px;
  }
  .project-content li::marker {
    color: var(--accent-primary);
    font-family: 'JetBrains Mono', monospace;
    font-weight: bold;
  }
  .project-content strong {
    color: #f4f4f5;
    font-weight: 600;
  }
  .project-content a {
    color: var(--accent-primary);
    text-decoration: underline;
    word-break: break-word;
  }
  .project-content code {
    background-color: #09090b;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 2px 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--accent-primary);
    word-break: break-word;
    white-space: pre-wrap;
  }
  .project-content pre {
    background-color: #09090b;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 14px;
    overflow-x: auto;
    margin: 16px 0;
    max-width: 100%;
  }
  .project-content pre code {
    background: transparent;
    border: none;
    padding: 0;
    font-size: 13px;
    color: #f4f4f5;
    word-break: normal;
    white-space: pre;
  }
</style>
