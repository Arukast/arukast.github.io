---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

import { render } from 'astro:content';

const { entry } = Astro.props;
const { Content } = await render(entry);


const statusColorMap: Record<string, string> = {
  'PRODUCTION': 'bg-emerald-950/20 text-emerald-400 border-emerald-900/40',
  'ONLINE': 'bg-emerald-950/20 text-emerald-400 border-emerald-900/40',
  'BLUEPRINT': 'bg-indigo-950/20 text-indigo-400 border-indigo-900/40',
  'STABLE': 'bg-zinc-900 text-zinc-400 border-[var(--border-color)]'
};

const statusColor = statusColorMap[entry.data.status.toUpperCase()] || 'bg-zinc-900 text-zinc-400 border-[var(--border-color)]';
---

<Layout title={`${entry.data.title} - Case Study`} description={entry.data.description}>
  <Navbar />

  <main class="flex-grow max-w-3xl w-full mx-auto px-6 py-10 space-y-8">
    <section class="space-y-4">
      <!-- Back button and Navigation Context -->
      <div class="flex justify-between items-center text-xs font-mono text-zinc-500">
        <span>/projects_inventory/{entry.slug}.md</span>
        <a href="/projects" class="text-zinc-400 hover:text-[var(--accent-primary)] transition flex items-center gap-1.5 bg-zinc-900 border border-[var(--border-color)] px-2.5 py-1 rounded-lg">
          <i class="fa-solid fa-arrow-left"></i> back_to_directory
        </a>
      </div>

      <!-- Title Header Block -->
      <div class="border-b border-[var(--border-color)] pb-6 space-y-3">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <h1 class="text-2xl font-bold font-mono text-white tracking-tight">{entry.data.title}</h1>
          <span class={`text-[10px] font-mono border px-2.5 py-0.5 rounded-md ${statusColor}`}>
            {entry.data.status}
          </span>
        </div>

        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-[11px] font-mono text-zinc-500">
          <span><strong class="text-zinc-400">Category:</strong> {entry.data.category}</span>
          <span>•</span>
          <div class="flex gap-1.5">
            {entry.data.tags.map(tag => (
              <span class="bg-zinc-900 px-1.5 py-0.2 rounded border border-zinc-800 text-[10px] text-zinc-400">{tag}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Project Architecture flow diagram if available -->
    {entry.data.architecture && entry.data.architecture.length > 0 && (
      <section class="bg-zinc-950 p-4 rounded-xl border border-[var(--border-color)] font-mono text-[10px] text-zinc-400 space-y-2">
        <p class="text-zinc-500">// Infrastructure Path Flow</p>
        <div class="flex flex-wrap items-center gap-2 text-xs">
          {entry.data.architecture.map((node, index) => (
            <>
              {index > 0 && <span class="text-zinc-600">→</span>}
              <span class={`bg-zinc-900 border border-zinc-800 px-2.5 py-1 rounded text-zinc-300 ${index === 1 ? 'font-semibold text-[var(--accent-primary)]' : ''}`}>
                {node}
              </span>
            </>
          ))}
        </div>
      </section>
    )}

    <!-- Dynamic Markdown Content Container -->
    <article class="project-content">
      <Content />
    </article>

    <!-- Source Link Footer -->
    <div class="pt-6 border-t border-[var(--border-color)] flex justify-between items-center text-xs font-mono">
      <span class="text-zinc-500">Sources available under public GPL v3.</span>
      <a href={entry.data.githubUrl} target="_blank" rel="noopener noreferrer" class="text-[var(--accent-primary)] hover:underline flex items-center gap-1.5">
        <i class="fa-brands fa-github"></i> view_sources.git
      </a>
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  /* Markdown Typography overrides */
  .project-content h3 {
    font-size: 14px;
    font-weight: bold;
    color: #f4f4f5;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 6px;
    margin-top: 28px;
    margin-bottom: 12px;
    text-transform: uppercase;
    font-family: 'JetBrains Mono', monospace;
  }
  .project-content p {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    line-height: 1.6;
    margin-bottom: 14px;
    color: #a1a1aa;
  }
  .project-content ul {
    list-style-type: square;
    padding-left: 20px;
    margin-bottom: 14px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: #a1a1aa;
  }
  .project-content li {
    margin-bottom: 6px;
  }
  .project-content strong {
    color: #f4f4f5;
    font-weight: 600;
  }
  .project-content code {
    background-color: #09090b;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 2px 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--accent-primary);
  }
  .project-content pre {
    background-color: #09090b;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 14px;
    overflow-x: auto;
    margin: 16px 0;
  }
  .project-content pre code {
    background: transparent;
    border: none;
    padding: 0;
    font-size: 11px;
    color: #f4f4f5;
  }
</style>
