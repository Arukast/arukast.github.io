version: '3.8'

services:
  caddy:
    image: caddy:2.8-alpine
    container_name: caddy
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./caddy/Caddyfile:/etc/caddy/Caddyfile
      - ./caddy/data:/data
      - ./caddy/config:/config
      - /var/www/portfolio:/usr/share/caddy
    networks:
      - caddy-net

networks:
  caddy-net:
    driver: bridge
    name: caddy-net
